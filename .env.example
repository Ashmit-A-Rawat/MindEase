# MindEase — canonical port map
# Copy this file per-service (backend/.env, ml-service/.env, etc.) and fill in real values.
# This root file exists only as the single source of truth for which port belongs to which service.

# ─────────────────────────────────────────────
# Service          Port    Type              Status
# ─────────────────────────────────────────────
# frontend         5173    Vite (React)      active
# backend          5001    Node/Express      active
# ml-service       5002    FastAPI           active (consolidated: risk, wellness-score, trend, clusters, associations)
# StudentVerification 8000 FastAPI           active (OCR verification, unchanged — frontend already hardcodes this)
# Spotify (server) 5005    Node/Express      active (permanent microservice — OAuth + playback proxy).
#                                            NOT 5000: macOS's AirPlay Receiver (Control Center) squats on
#                                            port 5000 by default and silently swallows anything else bound there.
#                                            No separate frontend — MusicTherapy.jsx (frontend/) talks to this
#                                            server directly; the old standalone Spotify frontend was removed.
# chat-service     5007    FastAPI           active (RAG "AI Support" chatbot, replaces the Chatbase iframe).
#                                            Gemini for embeddings + generation. Called directly from
#                                            ChatBot.jsx. Needs `npm run build:chat-index` once before first
#                                            use (and again whenever chat-service/documents/*.md changes).

# ───────────── backend/.env ─────────────
PORT=5001
MONGO_URI=
SESSION_SECRET=
JWT_SECRET=
CLIENT_URL=http://localhost:5173
CHAT_FRONTEND=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the Authorized Redirect URI registered in Google Cloud
# Console for this OAuth client (Credentials -> your OAuth 2.0 Client ID).
GOOGLE_CALLBACK_URL=http://localhost:5001/api1/auth/google/callback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ML_SERVICE_URL=http://127.0.0.1:5002
STUDENT_VERIFICATION_URL=http://localhost:8000

# ───────────── ml-service/.env (optional, currently unused by app.py but reserved) ─────────────
PORT=5002

# ───────────── StudentVerification — no .env currently; runs on fixed port 8000 ─────────────
# Requires Python >=3.11 (networkx==3.5 pin needs it). `npm run setup:python` uses python3.11 explicitly.

# ───────────── Spotify/.env ─────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must exactly match the redirect URI registered in the Spotify Developer Dashboard.
# It's the MAIN FRONTEND's root, not the Spotify server — Home.jsx catches the ?code=
# here (Spotify only allows a fixed, pre-registered redirect URI, and that's what was
# already registered when this was set up).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/
ADMIN_USER_ID=
PORT=5005

# ───────────── frontend/.env (all optional — every one of these has a
# localhost fallback baked into the code, so local dev works with none of
# this set. Only matters once you deploy somewhere other than localhost.) ──
VITE_API_URL=http://localhost:5001/api1
VITE_BACKEND_URL=http://localhost:5001
VITE_STUDENT_VERIFICATION_URL=http://localhost:8000
VITE_SPOTIFY_SERVICE_URL=http://localhost:5005
VITE_CHAT_SERVICE_URL=http://localhost:5007
# Optional dedicated TURN server for WebRTC calls (VideoCall.jsx) — without
# this, calls fall back to STUN + a free public TURN (Open Relay Project,
# best-effort/no uptime guarantee) which is enough for most home/campus
# networks but not guaranteed on strict corporate NATs. Get real credentials
# by self-hosting coturn or signing up with a provider (Metered.ca, Twilio,
# Xirsys all have usable free/low tiers).
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Emotion detection during video calls runs entirely client-side now
# (face-api.js/TensorFlow.js, models in frontend/public/models/) — no
# service, no .env, no port. See VideoCall.jsx.

# ───────────── chat-service/.env ─────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override — defaults to gemini-2.0-flash. Change if that model is
# retired/renamed by the time you're reading this; check https://ai.google.dev/gemini-api/docs/models
GEMINI_CHAT_MODEL=
